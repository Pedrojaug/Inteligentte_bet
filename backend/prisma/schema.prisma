generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// USUÁRIOS
// ═══════════════════════════════════════════
model User {
  id              String       @id @default(uuid())
  name            String
  email           String       @unique
  password        String
  phone           String?
  cpf             String?      @unique
  avatarUrl       String?
  asaasCustomerId String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  createdPools    Pool[]       @relation("PoolCreator")
  memberships     PoolMember[]
  bets            Bet[]
  payments        Payment[]
}

// ═══════════════════════════════════════════
// BOLÃO (Pool)
// ═══════════════════════════════════════════
model Pool {
  id                  String       @id @default(uuid())
  name                String
  description         String?
  code                String       @unique
  entryFee            Float
  maxParticipants     Int          @default(100)
  isPublic            Boolean      @default(true)
  status              PoolStatus   @default(OPEN)

  // Distribuição da premiação (% do pool líquido)
  prizeFirst          Float        @default(60)
  prizeSecond         Float        @default(25)
  prizeThird          Float        @default(15)

  // Jogo único deste bolão
  matchId             String?
  match               Match?       @relation(fields: [matchId], references: [id])

  creatorId           String
  creator             User         @relation("PoolCreator", fields: [creatorId], references: [id])

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  members             PoolMember[]
  bets                Bet[]
}

// ═══════════════════════════════════════════
// MEMBROS DO BOLÃO
// ═══════════════════════════════════════════
model PoolMember {
  id            String              @id @default(uuid())
  userId        String
  poolId        String
  role          PoolMemberRole      @default(MEMBER)
  totalPoints   Int                 @default(0)
  paymentStatus MemberPaymentStatus @default(PENDING)
  joinedAt      DateTime            @default(now())

  user          User     @relation(fields: [userId], references: [id])
  pool          Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId])
}

// ═══════════════════════════════════════════
// JOGOS DA COPA DO MUNDO
// ═══════════════════════════════════════════
model Match {
  id              String      @id @default(uuid())
  apiFootballId   Int         @unique
  homeTeam        String
  awayTeam        String
  homeFlag        String?
  awayFlag        String?
  homeScore       Int?
  awayScore       Int?
  status          MatchStatus @default(SCHEDULED)
  matchDate       DateTime
  group           String?
  round           String?
  stage           MatchStage  @default(GROUP)
  venue           String?
  city            String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  bets            Bet[]
  pools           Pool[]
}

// ═══════════════════════════════════════════
// APOSTAS
// ═══════════════════════════════════════════
model Bet {
  id          String   @id @default(uuid())
  userId      String
  poolId      String
  matchId     String
  homeScore   Int
  awayScore   Int
  points      Int      @default(0)
  scored      Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  pool        Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  match       Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, poolId, matchId])
}

// ═══════════════════════════════════════════
// PAGAMENTOS
// ═══════════════════════════════════════════
model Payment {
  id              String              @id @default(uuid())
  userId          String
  poolId          String?
  asaasPaymentId  String?             @unique
  amount          Float
  netAmount       Float?
  houseAmount     Float?
  status          MemberPaymentStatus @default(PENDING)
  billingType     String              @default("PIX")
  pixQrCode       String?             @db.Text
  pixCopyPaste    String?             @db.Text
  invoiceUrl      String?
  dueDate         DateTime
  paidAt          DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id])
}

// ═══════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════
enum PoolStatus {
  OPEN
  ACTIVE
  FINISHED
  CANCELLED
}

enum PoolMemberRole {
  CREATOR
  ADMIN
  MEMBER
}

enum MemberPaymentStatus {
  PENDING
  CONFIRMED
  OVERDUE
  REFUNDED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  EXTRA_TIME
  PENALTIES
  FINISHED
  POSTPONED
  CANCELLED
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

