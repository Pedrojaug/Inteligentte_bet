# ══════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════
DATABASE_URL="postgresql://postgres:senha@localhost:5432/bolao_inteligentte?schema=public"

# ══════════════════════════════════════════
# JWT
# ══════════════════════════════════════════
JWT_SECRET="sua-chave-secreta-muito-segura-aqui"

# ══════════════════════════════════════════
# ASAAS - Pagamentos
# ══════════════════════════════════════════
# Sandbox: https://api-sandbox.asaas.com/v3
# Produção: https://api.asaas.com/v3
ASAAS_API_URL="https://api-sandbox.asaas.com/v3"
ASAAS_API_KEY="sua-api-key-asaas"
ASAAS_WALLET_ID=""

# ══════════════════════════════════════════
# API-FOOTBALL - Placares ao vivo
# ══════════════════════════════════════════
# Dashboard: https://dashboard.api-sports.io/
FOOTBALL_API_KEY="sua-api-key-football"
FOOTBALL_API_URL="https://v3.football.api-sports.io"

# ══════════════════════════════════════════
# SERVER
# ══════════════════════════════════════════
PORT=3001
FRONTEND_URL="http://localhost:5173"

# ══════════════════════════════════════════
# COMISSÃO DA CASA (%)
# ══════════════════════════════════════════
HOUSE_COMMISSION=10
